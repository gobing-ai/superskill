{
    "name": "@gobing-ai/superskill",
    "type": "module",
    "private": true,
    "bin": {
        "superskill": "./superskill"
    },
    "files": [
        "superskill",
        "templates",
        "README.md"
    ],
    "engines": {
        "bun": ">=1.3.0"
    },
    "scripts": {
        "start": "bun run src/index.ts",
